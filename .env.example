# Environnement
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Base de données
DATABASE_URL=postgres://user:password@host:5432/gestion_locative

# CORS
# Origine du frontend autorisée (sera typiquement https://gestion.zeleph.fr en prod)
CORS_ORIGIN=http://localhost:5173

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Gestion Locative <no-reply@zeleph.fr>"

# Stockage des fichiers (volume Docker en prod, chemin local en dev)
FILES_STORAGE_PATH=./var/files
