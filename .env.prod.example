# Exemple d'environnement prod pour le VPS.
# Copier en `.env` dans `/root/persistent/gestion-locative-api/` avant le up -d.
# Aucune des valeurs ne doit JAMAIS être commitée — fichier listé dans .gitignore.

# ─── Database (utilise le Postgres déjà en place sur le VPS) ─────────────────
# Le %3F est l'encodage URL du '?' contenu dans le mot de passe — obligatoire
# pour que postgres-js parse l'URL correctement.
DATABASE_URL=postgres://gestionlocative_dev:<password-url-encoded>@host.docker.internal:5432/gestionlocative_dev

# ─── SMTP OVH (noreply@zeleph.fr déjà créé côté OVH) ─────────────────────────
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USER=noreply@zeleph.fr
SMTP_PASSWORD=<le-mot-de-passe-noreply>
SMTP_FROM="Gestion Locative <noreply@zeleph.fr>"

# ─── Image Docker ────────────────────────────────────────────────────────────
# À pointer vers le registry une fois la CI configurée :
#   ghcr.io/jarzur-dev-ui/gestion-locative-api:latest
# OU
#   registry.gitlab.exanders.fr/infrajo/gestion-locative-api:latest
# En attendant : laisser le default `gestion-locative-api:local` (build local)
# API_IMAGE=ghcr.io/jarzur-dev-ui/gestion-locative-api:latest
